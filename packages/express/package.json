{
  "name": "@ts-ioc-container/express",
  "version": "0.2.0",
  "description": "Express middleware for ts-ioc-container with automatic request-scoped container management",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "ibabkin <igba14@gmail.com>",
  "homepage": "https://igorbabkin.github.io/ts-ioc-container",
  "license": "ISC",
  "sideEffects": false,
  "main": "cjm/index.js",
  "types": "typings/index.d.ts",
  "module": "esm/index.js",
  "keywords": [
    "express",
    "middleware",
    "dependency-injection",
    "inversion-of-control",
    "container",
    "typescript",
    "ioc",
    "di",
    "scope"
  ],
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "cjm/**/*",
    "esm/**/*",
    "typings/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgorBabkin/ts-ioc-container",
    "directory": "packages/express"
  },
  "scripts": {
    "build:cjm": "rimraf cjm && tsc -p tsconfig.production.json --outDir cjm --module CommonJS",
    "build:esm": "rimraf esm && tsc -p tsconfig.production.json --outDir esm",
    "build:types": "rimraf typings && tsc -p tsconfig.production.json --outDir typings --emitDeclarationOnly --declaration",
    "build": "pnpm run build:cjm && pnpm run build:esm && pnpm run build:types",
    "test": "jest --maxWorkers=2",
    "test:coverage": "jest --maxWorkers=2 --coverage --coverageReporters=lcov --coverageReporters=text-summary",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "eslint lib/**/*.ts __tests__/**/*.ts",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier --write \"**/*.ts\"",
    "release": "pnpm run build && pnpm test && pnpm publish"
  },
  "peerDependencies": {
    "@types/express": "^4.17.0 || ^5.0.0",
    "express": "^4.0.0 || ^5.0.0",
    "ts-ioc-container": "^46.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "29.5.14",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "8.29.1",
    "@typescript-eslint/parser": "8.29.1",
    "eslint": "9.24.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-prettier": "5.2.6",
    "express": "^4.18.2",
    "jest": "29.7.0",
    "prettier": "3.5.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "6.0.1",
    "ts-ioc-container": "workspace:*",
    "ts-jest": "29.3.1",
    "typescript": "5.8.3"
  }
}
