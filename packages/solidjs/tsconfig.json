{
  "compilerOptions": {
    "baseUrl": "./lib",
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["es2022", "dom"],
    "types": ["solid-js", "node"],
    "moduleResolution": "Node",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "noImplicitReturns": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["lib"],
  "exclude": ["node_modules", "cjm", "esm", "typings"]
}
