---
import BaseLayout from "../layouts/BaseLayout.astro";

const benchmarkModules = import.meta.glob("../../../__benchmarks__/specs/*.benchmark.ts");
const availableSpecs = Object.keys(benchmarkModules)
  .map((path) => path.split("/").pop()?.replace(/\.benchmark\.ts$/, ""))
  .filter((prefix): prefix is string => Boolean(prefix))
  .sort();

const implementationOrder = ["ts-ioc-container", "tsyringe"];
const getBenchmarkKey = (prefix: string) =>
  prefix.replace(/\.(ts-ioc-container|tsyringe)$/, "");
const getImplementation = (prefix: string) => prefix.replace(`${getBenchmarkKey(prefix)}.`, "");
const formatBenchmarkLabel = (key: string) =>
  key
    .split("-")
    .map((word) => word[0]?.toUpperCase() + word.slice(1))
    .join(" ");
const sortSpecs = (specs: string[]) =>
  specs.toSorted((a, b) => {
    const implementationA = getImplementation(a);
    const implementationB = getImplementation(b);
    const orderA = implementationOrder.indexOf(implementationA);
    const orderB = implementationOrder.indexOf(implementationB);
    const normalizedOrderA = orderA === -1 ? implementationOrder.length : orderA;
    const normalizedOrderB = orderB === -1 ? implementationOrder.length : orderB;

    return normalizedOrderA - normalizedOrderB || a.localeCompare(b);
  });

const benchmarkGroups = Array.from(
  availableSpecs.reduce((groups, spec) => {
    const key = getBenchmarkKey(spec);
    groups.set(key, [...(groups.get(key) || []), spec]);
    return groups;
  }, new Map<string, string[]>()),
  ([key, specs]) => ({
    key,
    specs: sortSpecs(specs),
  }),
)
  .map((group) => ({
    ...group,
    label: `${formatBenchmarkLabel(group.key)} (${group.specs.map(getImplementation).join(", ")})`,
  }))
  .sort((a, b) => a.label.localeCompare(b.label));
const defaultBenchmark = benchmarkGroups.some((group) => group.key === "dependency-resolution")
  ? "dependency-resolution"
  : benchmarkGroups[0]?.key;
---

<BaseLayout
  title="Benchmarks"
  description="Run and compare benchmark specs directly in the browser."
>
  <article class="benchmark-page">
    <h1>Benchmarks</h1>

    <section aria-labelledby="benchmark-runner">
      <h2 id="benchmark-runner">Benchmark Runner</h2>

      <form id="benchmark-form" class="benchmark-controls">
        <label class="form-label" for="benchmark-pair">Benchmark</label>
        <select class="form-select" id="benchmark-pair" name="benchmark">
          {
            benchmarkGroups.map((group) => (
              <option value={group.key} selected={group.key === defaultBenchmark}>{group.label}</option>
            ))
          }
        </select>

        <label class="form-label" for="benchmark-duration">Duration</label>
        <select class="form-select" id="benchmark-duration" name="duration">
          <option value="500">500 ms</option>
          <option value="1000" selected>1 second</option>
          <option value="2000">2 seconds</option>
          <option value="5000">5 seconds</option>
        </select>

        <button class="btn btn-primary" id="benchmark-run" type="submit">
          Run benchmark
        </button>
      </form>

      <div id="benchmark-status" class="benchmark-status" role="status">
        Ready to run the selected benchmark.
      </div>
    </section>

    <section aria-labelledby="benchmark-results">
      <h2 id="benchmark-results">Results</h2>

      <div class="table-responsive">
        <table class="table table-striped align-middle" id="benchmark-table">
          <thead>
            <tr>
              <th scope="col">Spec</th>
              <th scope="col">Task</th>
              <th scope="col">Ops/sec</th>
              <th scope="col">Mean</th>
              <th scope="col">Samples</th>
              <th scope="col">Relative</th>
            </tr>
          </thead>
          <tbody id="benchmark-results-body">
            <tr>
              <td colspan="6">No run yet.</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="benchmark-note">
        Query example:
        <code>?benchmark=dependency-resolution</code>
      </p>
    </section>
  </article>

  <script>
    import "reflect-metadata";

    const modules = import.meta.glob("../../../__benchmarks__/specs/*.benchmark.ts");
    const moduleByPrefix = new Map(
      Object.entries(modules).map(([path, loader]) => [
        path.split("/").pop().replace(/\.benchmark\.ts$/, ""),
        loader,
      ]),
    );
    const availableSpecs = Array.from(moduleByPrefix.keys()).sort();
    const implementationOrder = ["ts-ioc-container", "tsyringe"];
    const getBenchmarkKey = (prefix) => prefix.replace(/\.(ts-ioc-container|tsyringe)$/, "");
    const getImplementation = (prefix) => prefix.replace(`${getBenchmarkKey(prefix)}.`, "");
    const sortSpecs = (specs) =>
      specs.toSorted((a, b) => {
        const implementationA = getImplementation(a);
        const implementationB = getImplementation(b);
        const orderA = implementationOrder.indexOf(implementationA);
        const orderB = implementationOrder.indexOf(implementationB);
        const normalizedOrderA = orderA === -1 ? implementationOrder.length : orderA;
        const normalizedOrderB = orderB === -1 ? implementationOrder.length : orderB;

        return normalizedOrderA - normalizedOrderB || a.localeCompare(b);
      });
    const benchmarkGroups = Array.from(
      availableSpecs.reduce((groups, spec) => {
        const key = getBenchmarkKey(spec);
        groups.set(key, [...(groups.get(key) || []), spec]);
        return groups;
      }, new Map()),
      ([key, specs]) => ({
        key,
        specs: sortSpecs(specs),
      }),
    );
    const benchmarkByKey = new Map(benchmarkGroups.map((group) => [group.key, group]));
    const defaultBenchmark = benchmarkByKey.has("dependency-resolution")
      ? "dependency-resolution"
      : benchmarkGroups[0]?.key;

    const form = document.querySelector("#benchmark-form");
    const benchmarkInput = document.querySelector("#benchmark-pair");
    const durationInput = document.querySelector("#benchmark-duration");
    const runButton = document.querySelector("#benchmark-run");
    const status = document.querySelector("#benchmark-status");
    const resultsBody = document.querySelector("#benchmark-results-body");

    const formatHz = (value) =>
      new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 }).format(value);
    const formatMean = (value) =>
      `${new Intl.NumberFormat(undefined, { maximumFractionDigits: 4 }).format(value)} ms`;

    const setStatus = (message) => {
      status.textContent = message;
    };

    const toBenchmarkFile = (prefix) => `${prefix}.benchmark.ts`;

    const renderBenchmarkStatuses = (items) => {
      setStatus(items.map((item) => `${toBenchmarkFile(item.prefix)}: ${item.state}`).join("\n"));
    };

    const readQuery = () => {
      const params = new URLSearchParams(window.location.search);
      const benchmark = params.get("benchmark");
      const spec1 = params.get("spec1");
      const duration = params.get("duration");

      if (benchmarkByKey.has(benchmark)) {
        benchmarkInput.value = benchmark;
      } else if (availableSpecs.includes(spec1)) {
        benchmarkInput.value = getBenchmarkKey(spec1);
      } else {
        benchmarkInput.value = defaultBenchmark;
      }

      if (duration && durationInput.querySelector(`option[value="${duration}"]`)) {
        durationInput.value = duration;
      }
    };

    const writeQuery = () => {
      const params = new URLSearchParams({
        benchmark: benchmarkInput.value,
        duration: durationInput.value,
      });
      window.history.replaceState(null, "", `${window.location.pathname}?${params}`);
    };

    const loadSpec = async (prefix) => {
      const loader = moduleByPrefix.get(prefix);

      if (!loader) {
        throw new Error(`Unknown benchmark spec: ${prefix}`);
      }

      const module = await loader();
      return module.benchmarkSpec;
    };

    const measure = async (prefix, durationMs) => {
      const spec = await loadSpec(prefix);
      const task = spec.createTask();
      const warmupUntil = performance.now() + Math.min(250, durationMs / 2);

      while (performance.now() < warmupUntil) {
        task();
      }

      const samples = [];
      let iterations = 0;
      const startedAt = performance.now();
      let chunkStartedAt = startedAt;
      let chunkIterations = 0;

      while (performance.now() - startedAt < durationMs) {
        task();
        iterations += 1;
        chunkIterations += 1;

        const now = performance.now();

        if (now - chunkStartedAt >= 50) {
          samples.push({
            iterations: chunkIterations,
            duration: now - chunkStartedAt,
          });
          chunkStartedAt = now;
          chunkIterations = 0;
          await new Promise((resolve) => setTimeout(resolve, 0));
        }
      }

      const finishedAt = performance.now();

      if (chunkIterations > 0) {
        samples.push({
          iterations: chunkIterations,
          duration: finishedAt - chunkStartedAt,
        });
      }

      const duration = finishedAt - startedAt;
      const hz = iterations / (duration / 1000);

      return {
        prefix,
        name: spec.name,
        taskName: spec.taskName,
        description: spec.description,
        iterations,
        samples: samples.length,
        duration,
        hz,
        meanMs: duration / iterations,
      };
    };

    const renderResults = (results) => {
      const fastest = Math.max(...results.map((result) => result.hz));

      resultsBody.innerHTML = results
        .map((result) => {
          const ratio = result.hz / fastest;
          const relative =
            ratio === 1
              ? "fastest"
              : `${new Intl.NumberFormat(undefined, { maximumFractionDigits: 2 }).format(1 / ratio)}x slower`;

          return `<tr>
            <th scope="row">
              <div>${result.name}</div>
              <small class="text-body-secondary">${result.prefix}</small>
            </th>
            <td>${result.taskName}</td>
            <td>${formatHz(result.hz)}</td>
            <td>${formatMean(result.meanMs)}</td>
            <td>${result.samples}</td>
            <td>${relative}</td>
          </tr>`;
        })
        .join("");
    };

    const runComparison = async () => {
      const benchmark = benchmarkByKey.get(benchmarkInput.value);
      const duration = Number(durationInput.value);
      const benchmarkStatuses =
        benchmark?.specs.map((spec) => ({
          prefix: spec,
          state: "pending",
        })) || [];

      runButton.disabled = true;
      resultsBody.innerHTML = '<tr><td colspan="6">Running...</td></tr>';
      writeQuery();

      try {
        if (!benchmark) {
          throw new Error("No benchmark selected.");
        }

        const results = [];

        renderBenchmarkStatuses(benchmarkStatuses);

        for (const [index, spec] of benchmark.specs.entries()) {
          benchmarkStatuses[index].state = "running";
          renderBenchmarkStatuses(benchmarkStatuses);

          results.push(await measure(spec, duration));

          benchmarkStatuses[index].state = "done";
          renderBenchmarkStatuses(benchmarkStatuses);
        }

        renderResults(results);
      } catch (error) {
        const runningStatus = benchmarkStatuses.find((item) => item.state === "running");
        if (runningStatus) {
          runningStatus.state = "failed";
        }
        if (benchmarkStatuses.length > 0) {
          renderBenchmarkStatuses(benchmarkStatuses);
        }
        resultsBody.innerHTML = `<tr><td colspan="6">${error.message}</td></tr>`;
      } finally {
        runButton.disabled = false;
      }
    };

    readQuery();

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      runComparison();
    });

    if (window.location.search) {
      runComparison();
    }
  </script>

  <style>
    .benchmark-page {
      max-width: 1120px;
    }

    .benchmark-controls {
      display: grid;
      grid-template-columns: minmax(10rem, max-content) minmax(14rem, 1fr);
      gap: 0.75rem 1rem;
      align-items: center;
      margin: 1.5rem 0;
    }

    .benchmark-controls .btn {
      grid-column: 2;
      width: max-content;
    }

    .benchmark-status {
      min-height: 2.5rem;
      padding: 0.75rem 1rem;
      border: 1px solid var(--bs-border-color);
      border-radius: 0.25rem;
      background: var(--bs-tertiary-bg);
      white-space: pre-line;
    }

    .benchmark-note {
      margin-top: 1rem;
      color: var(--bs-secondary-color);
    }

    @media (max-width: 720px) {
      .benchmark-controls {
        grid-template-columns: 1fr;
      }

      .benchmark-controls .btn {
        grid-column: 1;
        width: 100%;
      }
    }
  </style>
</BaseLayout>
