{
  "name": "ts-ioc-container-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for ts-ioc-container",
  "workspaces": [
    "docs",
    "packages/*"
  ],
  "scripts": {
    "build": "lerna run build --ignore ts-ioc-container-docs",
    "test": "lerna run test",
    "test:coverage": "lerna run test:coverage",
    "type-check": "lerna run type-check",
    "lint": "lerna run lint --ignore ts-ioc-container-docs",
    "lint:fix": "lerna run lint:fix --ignore ts-ioc-container-docs",
    "format": "lerna run format --ignore ts-ioc-container-docs",
    "generate:docs": "lerna run generate:docs",
    "commit": "npx cz",
    "prepare": "husky",
    "release": "lerna publish",
    "changed": "lerna changed",
    "diff": "lerna diff",
    "docs:build": "pnpm --filter ts-ioc-container-docs run build",
    "docs:preview": "pnpm --filter ts-ioc-container-docs run preview"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "8.29.1",
    "@typescript-eslint/parser": "8.29.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "9.24.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-prettier": "5.2.6",
    "husky": "^9.1.7",
    "lerna": "^9.0.3",
    "lint-staged": "^15.5.0",
    "prettier": "3.5.3",
    "prettier-plugin-astro": "^0.14.1"
  },
  "lint-staged": {
    "packages/**/*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "docs/**/*.{js,ts,tsx,mjs,astro}": [
      "prettier --write"
    ],
    "docs/**/*.astro": [
      "eslint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@10.20.0+sha512.cf9998222162dd85864d0a8102e7892e7ba4ceadebbf5a31f9c2fce48dfce317a9c53b9f6464d1ef9042cba2e02ae02a9f7c143a2b438cd93c91840f0192b9dd"
}
